<div class="container">

    <h1>Mini Tienda MongoDB + Mongoose</h1>

    {{#if error}}
        <div class="error">
            {{error}}
        </div>
    {{/if}}

    <!-- ===================== -->
    <!-- CREAR -->
    <!-- ===================== -->

    <div class="card">

        <h2>Nuevo producto</h2>

        <form class="form" action="/productos/crear" method="POST">

            <select
                id="categoriaCrear"
                name="categoria"
                onchange="renderCampos()">

                <option value="">Seleccionar categoría</option>
                <option value="ropa">Ropa</option>
                <option value="electronica">Electrónica</option>
                <option value="muebles">Muebles</option>

            </select>

            <input
                name="nombre"
                placeholder="Nombre">

            <input
                name="precio"
                placeholder="Precio">

            <input
                name="stock"
                placeholder="Stock">

            <input
                name="tags"
                placeholder="Tags separados por coma">

            <div id="camposExtra"></div>

            <button class="btn btn-primary">
                Crear producto
            </button>

        </form>

    </div>

    <!-- ===================== -->
    <!-- FILTROS -->
    <!-- ===================== -->

    <div class="card">

        <h2>Buscar productos</h2>

        <form
            class="filters"
            action="/productos"
            method="GET">

            <select name="categoria">

                <option value="">Todas</option>
                <option value="ropa">Ropa</option>
                <option value="electronica">Electrónica</option>
                <option value="muebles">Muebles</option>

            </select>

            <input
                name="nombre"
                placeholder="Buscar por nombre"
                value="{{nombreActual}}">

            <label>

                <input
                    type="checkbox"
                    name="garantia"
                    value="1"
                    {{#if garantiaActual}}checked{{/if}}>

                Con garantía

            </label>

            <label>

                <input
                    type="checkbox"
                    name="activo"
                    value="1"
                    {{#if activoActual}}checked{{/if}}>

                Solo activos

            </label>

            <button class="btn btn-success">
                Buscar
            </button>

        </form>

    </div>

    <!-- ===================== -->
    <!-- LISTADO -->
    <!-- ===================== -->

    <div class="lista-productos">

        {{#each productos}}

            <div class="card producto">

                <h3>{{nombre}}</h3>

                <p>

                    <span class="badge">

                        {{categoria}}

                    </span>

                    <strong>${{precio}}</strong>

                </p>

                <p>

                    📦 Stock: {{stock}}

                </p>

                {{#if talles}}

                    <p>

                        👕 Talles: {{talles}}

                    </p>

                {{/if}}

                {{#if marca}}

                    <p>

                        🏷️ Marca: {{marca}}

                    </p>

                {{/if}}

                {{#if garantia}}

                    <p>

                        🛡️ Garantía: {{garantia}} meses

                    </p>

                {{/if}}

                {{#if material}}

                    <p>

                        🪵 Material: {{material}}

                    </p>

                {{/if}}

                {{#if tags.length}}

                    <p>

                        Tags:

                        {{#each tags}}

                            <span class="badge">

                                {{this}}

                            </span>

                        {{/each}}

                    </p>

                {{/if}}

                <form
                    action="/productos/eliminar/{{_id}}"
                    method="POST">

                    <button
                        class="btn btn-danger">

                        Eliminar

                    </button>

                </form>

            </div>

        {{/each}}

    </div>
    <div class="paginacion">

{{#if hasPrev}}

<a
class="btn btn-success"
href="/productos?page={{prevPage}}">

← Anterior

</a>

{{/if}}

<span>

Página {{page}} de {{totalPages}}

</span>

{{#if hasNext}}

<a
class="btn btn-success"
href="/productos?page={{nextPage}}">

Siguiente →

</a>

{{/if}}

</div>

</div>

<script>

function renderCampos(){

    const categoria=document.getElementById("categoriaCrear").value;

    const container=document.getElementById("camposExtra");

    container.innerHTML="";

    if(categoria==="ropa"){

        container.innerHTML=`

            <input
                name="talles"
                placeholder="Talles (S,M,L)">

        `;

    }

    if(categoria==="electronica"){

        container.innerHTML=`

            <input
                name="marca"
                placeholder="Marca">

            <input
                name="garantia"
                placeholder="Garantía (meses)">

        `;

    }

    if(categoria==="muebles"){

        container.innerHTML=`

            <input
                name="material"
                placeholder="Material">

            <input
                name="alto"
                placeholder="Alto">

            <input
                name="ancho"
                placeholder="Ancho">

        `;

    }

}

</script>